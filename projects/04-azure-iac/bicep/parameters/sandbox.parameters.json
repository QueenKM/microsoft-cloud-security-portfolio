{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentParameters.json#",
  "contentVersion": "1.0.0.0",
  "parameters": {
    "location": {
      "value": "westeurope"
    },
    "environmentName": {
      "value": "sandbox"
    },
    "workloadPrefix": {
      "value": "astera"
    },
    "tags": {
      "value": {
        "costCenter": "portfolio",
        "dataClassification": "lab",
        "owner": "QueenKM"
      }
    },
    "logAnalyticsRetentionInDays": {
      "value": 30
    },
    "storageSku": {
      "value": "Standard_LRS"
    },
    "enableStorageVersioning": {
      "value": true
    },
    "enableResourceDiagnostics": {
      "value": true
    },
    "virtualNetworkAddressPrefixes": {
      "value": [
        "10.42.0.0/16"
      ]
    },
    "managementSubnetAddressPrefix": {
      "value": "10.42.1.0/24"
    },
    "workloadSubnetAddressPrefix": {
      "value": "10.42.2.0/24"
    },
    "deployDemoVirtualMachine": {
      "value": false
    },
    "demoVirtualMachineSize": {
      "value": "Standard_B1s"
    },
    "demoVirtualMachineAdminUsername": {
      "value": "azureuser"
    },
    "demoVirtualMachineSshPublicKey": {
      "value": ""
    },
    "demoVirtualMachinePublicIpEnabled": {
      "value": false
    },
    "itAdminPrincipalId": {
      "value": ""
    },
    "itAdminPrincipalType": {
      "value": "Group"
    },
    "securityAnalystPrincipalId": {
      "value": ""
    },
    "securityAnalystPrincipalType": {
      "value": "Group"
    }
  }
}
